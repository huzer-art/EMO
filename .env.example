# CBT-MAS

# base llm
LLM_API_KEY=sk-YouApi
LLM_BASE_URL=https://api.deepseek.com

# Front model (System 1)
THERAPIST_API_KEY=sk-YouApi
THERAPIST_BASE_URL=https://api.deepseek.com
THERAPIST_MODEL=deepseek-chat

# Back model (System 2)
SUPERVISOR_API_KEY=sk-YouApi
SUPERVISOR_BASE_URL=https://api.deepseek.com
SUPERVISOR_MODEL=deepseek-v4-pro

# Judge model
JUDGE_API_KEY=sk-YouApi
JUDGE_BASE_URL=https://api.deepseek.com
JUDGE_MODEL=deepseek-ai/deepseek-v4-pro

# 用于 baseline 评测
BASELINE_API_KEY=sk-YouApi
BASELINE_BASE_URL=https://api.deepseek.com
BASELINE_MODEL=deepseek-v4-pro

# setting
DEBUG=true
MAX_TURNS_PER_STAGE=15

# 测试阶段关闭危机检测，避免评测语料中的危机关键词打断 CBT 流程
ENABLE_CRISIS_DETECTION=false

# 正式上线时恢复
# ENABLE_CRISIS_DETECTION=true